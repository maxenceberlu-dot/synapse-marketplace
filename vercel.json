{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "redirects": [
    { "source": "/pronostics-entreprise", "destination": "/pronostics-sportifs-entreprise.html", "statusCode": 301 },
    { "source": "/pronostics-entreprise.html", "destination": "/pronostics-sportifs-entreprise.html", "statusCode": 301 },
    { "source": "/application-pronostics-entreprise", "destination": "/pronostics-sportifs-entreprise.html", "statusCode": 301 },
    { "source": "/application-pronostics-entreprise.html", "destination": "/pronostics-sportifs-entreprise.html", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/.well-known/ai-plugin.json", "destination": "/ai-plugin.json" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://embed.tawk.to https://*.tawk.to; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co https://*.tawk.to wss://*.tawk.to; frame-src https://*.tawk.to" }
      ]
    },
    {
      "source": "/dashboard.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
